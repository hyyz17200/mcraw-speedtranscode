{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcraw-transcoder.invalid/schema/config-v1.json",
  "title": "mcraw-transcoder configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version"],
  "properties": {
    "schema_version": {"const": 1},
    "demosaic": {"enum": ["rcd", "amaze", "igv", "dcb", "lmmse"], "default": "rcd"},
    "exposure_offset_stops": {"type": "number", "default": 0.0},
    "negative_policy": {
      "enum": ["preserve_by_curve", "clamp_zero", "error"],
      "default": "preserve_by_curve"
    },
    "chroma_filter": {"enum": ["fast", "quality"], "default": "quality"},
    "capture_sharpening": {"type": "number", "minimum": 0.0, "maximum": 2.0, "default": 0.4},
    "capture_sharpening_threshold": {"type": "number", "minimum": 0.0, "maximum": 0.1, "default": 0.002},
    "deterministic_dither": {"type": "boolean", "default": true},
    "preserve_source_timestamps": {"const": true},
    "preserve_audio": {"type": "boolean", "default": true},
    "max_frames": {"type": "integer", "minimum": 0, "default": 0},
    "cpu_threads": {"type": "integer", "minimum": 0, "maximum": 256, "default": 0},
    "max_parallel_frames": {"type": "integer", "minimum": 0, "maximum": 64, "default": 0},
    "target_profile": {"const": "DaVinciIntermediate_DWG"},
    "prores_profile": {"const": "hq"},
    "backend": {"enum": ["auto", "cpu", "vulkan"], "default": "cpu"},
    "gpu_selector": {"type": "string", "minLength": 1, "default": "auto"},
    "async_depth": {"type": "integer", "minimum": 1, "maximum": 64, "default": 8},
    "fallback": {"enum": ["prores_ks", "none"], "default": "prores_ks"},
    "precision": {"enum": ["fp32", "fp16"], "default": "fp32"}
  }
}
